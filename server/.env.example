PORT=5000
CLIENT_URL=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/visionbridge

# AI — Gemini Vision (FREE tier)
# Get your free key at: https://aistudio.google.com/apikey
# Free limits: 15 req/min · 1,500 req/day — no credit card required
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — pin a specific Gemini model (leave blank to auto-select)
# The server tries models in order until one works:
#   gemini-2.0-flash → gemini-1.5-flash → gemini-2.0-flash-lite
# Find available models: https://aistudio.google.com/app/prompts
# GEMINI_MODEL=gemini-2.0-flash

# Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Auth & Notifications
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
